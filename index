        </footer>

    <script>
        function mostrar(id){
            let paginas  = document.querySelectorAll('.pagina');

            paginas.forEach(function(pagina){
                pagina.style.display = 'none';
            });
            
            document.getElementById(id).style.display ='block';
        }
    </script>

</body>
