    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dia Mundial do Karatê</title>

    <link rel="stylesheet" href="style.css">
</head>
 



<body>

    <header>
        <h1 id="titulo">DIA MUNDIAL DO KARATÊ 🥋</h1>
    </header>

    <nav>
        <ul>
            <li><a href="#"onclick="mostrar('home')">HOME</a></li>
            <li><a href="#"onclick="mostrar('sobre')">SOBRE</a></li>
            <li><a href="#"onclick="mostrar('benefícios')">BENEFÍCIOS</a></li>
